{
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "build": "pnpm build:demo",
    "build:demo": "pnpm -C demo build",
    "ci:publish": "pnpm -r publish --access public --no-git-checks",
    "dev": "pnpm demo",
    "dev:local": "node scripts/toggle-local-shuimo-core.mjs on && pnpm install && pnpm dev",
    "dev:reset": "node scripts/toggle-local-shuimo-core.mjs off && pnpm install && pnpm dev",
    "demo": "pnpm -C demo dev",
    "lint": "eslint .",
    "release": "pnpm build && cd theme && git add -A && bumpp --all && pnpm -r publish --access public --no-git-checks",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "vue-tsc --noEmit --skipLibCheck"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:",
    "@unocss/eslint-plugin": "catalog:",
    "bumpp": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-format": "catalog:",
    "typescript": "catalog:",
    "valaxy-theme-shuimo": "workspace:@jobinjia/valaxy-theme-shuimo@*",
    "vitest": "catalog:",
    "vue-tsc": "catalog:"
  }
}
